# Gradle
.gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# Gradle Wrapper - COMMIT THESE (essential for reproducible builds)
# The wrapper files ensure everyone uses the same Gradle version
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties
!gradlew
!gradlew.bat

