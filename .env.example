# ─────────────────────────────────────────────────────────────────────────────
# Enfila Backend — Environment Variables Template
# Copy this file to .env on the server: cp .env.example .env
# Fill in all values. NEVER commit the .env file to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_NAME=enfila_db
DB_USER=enfila_user
DB_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD

# ── Twilio ────────────────────────────────────────────────────────────────────
# Found at: https://console.twilio.com → Account Info
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_twilio_auth_token

# ── GitHub Container Registry (GHCR) ─────────────────────────────────────────
# A GitHub Personal Access Token with read:packages scope.
# Used by the VPS to pull the Docker image from GHCR.
# Create at: https://github.com/settings/tokens → Generate new token (classic)
# Required scopes: read:packages
GHCR_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GHCR_USER=ingjuanocampo
